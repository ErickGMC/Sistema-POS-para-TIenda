rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla global: El usuario debe estar autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // PRODUCTOS:
    // - Lectura pública para la tienda web y catálogo
    // - Escritura solo para empleados logueados
    match /productos/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // VENTAS Y DETALLES:
    // - Información de ventas, detalles y correlativo. Solo empleados logueados.
    match /ventas/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /ventas_detalle/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /ventas_correlativo/{document=**} {
      allow read, write: if isAuthenticated();
    }
    match /correlativos/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // ANALYTICS EVENTS:
    // - Las visitas a la web se registran de forma anónima (create público)
    // - Solo los empleados pueden leerlas (para el Dashboard)
    match /analytics_events/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // USUARIOS (Roles):
    // - Solo empleados autenticados pueden leer/escribir.
    match /usuarios/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // WEB CONFIG:
    // - Lectura pública para la tienda web (necesita config de WhatsApp, nombre, etc.)
    // - Escritura solo para empleados logueados
    match /web_config/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // BANNERS:
    // - Lectura pública para la tienda web
    // - Escritura solo para empleados logueados
    match /banners/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // LISTAS DE COMPRA (Reabastecimiento):
    // - Solo empleados logueados
    match /compras_listas/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // AUDITORÍA:
    // - Solo empleados logueados
    match /audit_logs/{document=**} {
      allow read, write: if isAuthenticated();
    }

  }
}
